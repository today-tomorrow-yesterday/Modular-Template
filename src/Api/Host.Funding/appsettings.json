{
  "Application": {
    "Name": "Rtl.Core.Funding",
    "DisplayName": "Funding API",
    "ShortName": "funding-api",
    "DatabaseName": "funding"
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=funding;Username=postgres;Password=postgres",
    "Cache": "localhost:6379"
  },
  "Authentication": {
    "TenantId": "your-azure-ad-tenant-id",
    "Audience": "api://your-app-client-id",
    "RequireHttpsMetadata": true
  },
  "Features": {
    "Infrastructure": {
      "Outbox": true,
      "Inbox": true,
      "Emails": false,
      "CdcEvents": true,
      "BackgroundJobs": true
    },
    "Module": {}
  },
  "Messaging": {
    "Outbox": {
      "IntervalInSeconds": 10,
      "BatchSize": 20,
      "MaxRetries": 5
    },
    "Inbox": {
      "IntervalInSeconds": 10,
      "BatchSize": 20,
      "MaxRetries": 5
    },
    "SqsConsumer": {
      "SqsQueueUrl": "",
      "PollingIntervalSeconds": 5,
      "MaxMessages": 10,
      "VisibilityTimeoutSeconds": 30
    },
    "EmbProducer": {
      "EventBus": "",
      "CostCenter": "rtl",
      "EventSource": "rtl",
      "Reporter": "rtl.core"
    }
  },
  "Caching": {
    "DefaultExpirationMinutes": 5
  },
  "HealthChecks": {
    "OutboxLag": {
      "DegradedThresholdSeconds": 60,
      "UnhealthyThresholdSeconds": 300,
      "DegradedCountThreshold": 100,
      "UnhealthyCountThreshold": 1000
    },
    "InboxLag": {
      "DegradedThresholdSeconds": 60,
      "UnhealthyThresholdSeconds": 300,
      "DegradedCountThreshold": 100,
      "UnhealthyCountThreshold": 1000
    },
    "SqsQueueDepth": {
      "QueueUrl": "",
      "DegradedThreshold": 1000,
      "UnhealthyThreshold": 10000,
      "IncludeDeadLetterQueue": true,
      "DeadLetterQueueUrl": "",
      "DeadLetterQueueUnhealthyThreshold": 1
    },
    "ModuleDefaults": {
      "OutboxDegradedThresholdSeconds": 60,
      "OutboxUnhealthyThresholdSeconds": 300,
      "OutboxDegradedCountThreshold": 50,
      "OutboxUnhealthyCountThreshold": 500
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
    "Cors": {
        "AllowedOrigins": []
    },
    "RateLimiting": {
        "PermitLimit": 100,
        "WindowInSeconds": 60,
        "QueueLimit": 0
    },
    "Secrets": {
        "CacheDurationMinutes": 5
    },
    "ISeries": {
        "BaseUrl": "http://localhost:9999",
        "SigningKeySecretName": "",
        "ValidIssuer": "rtl-core",
        "ValidAudience": "iseries-gateway",
        "TokenLifetimeMinutes": 5
    },
    "Resilience": {
        "Retry": {
            "MaxRetryAttempts": 3,
            "BaseDelayMilliseconds": 1000,
            "UseJitter": true
        },
        "CircuitBreaker": {
            "SamplingDurationSeconds": 10,
            "FailureRatio": 0.2,
            "MinimumThroughput": 3,
            "BreakDurationSeconds": 30
        },
        "Timeout": {
            "TotalTimeoutSeconds": 30,
            "AttemptTimeoutSeconds": 10
        }
    }
}
