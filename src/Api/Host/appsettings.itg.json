{
  "ConnectionStrings": {
    "Database": "Host=itg-db-host;Database=rtlcore;Username=app_user;Password=PLACEHOLDER",
    "Cache": "itg-cache-host:6379"
  },
  "DatabaseSecret": {
    "SecretName": "itg-rtl-rds-sql-master",
    "DatabaseName": "rtlcore",
    "SslMode": "Require"
  },
  "Secrets": {
    "CacheDurationMinutes": 5
  },
  "ISeries": {
    "BaseUrl": "https://dat.itg.cmhlink.net/retail/net/api/iSeries/rtl/sys/iseries/",
    "SigningKeySecretName": "itg-rtl-iseries-jwt-signing-key"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Seeding": {
    "Enabled": true
  }
}
