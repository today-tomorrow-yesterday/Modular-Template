{
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=sales_dev;Username=postgres;Password=postgres",
    "Cache": "localhost:6379"
  },
  "Encryption": {
    "Key": "MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI="
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://localhost:3000",
      "https://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
