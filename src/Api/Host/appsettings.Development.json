      "SamplingDurationSeconds": 5,
      "FailureRatio": 0.3,
      "MinimumThroughput": 2,
      "BreakDurationSeconds": 10
    },
    "Timeout": {
      "TotalTimeoutSeconds": 10,
      "AttemptTimeoutSeconds": 3
    }
  },
  "Seeding": {
    "Enabled": true
  },
  "Modules": {
